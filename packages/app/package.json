{
  "name": "@open-nova/app",
  "version": "0.1.0",
  "description": "open-nova desktop app (Electron + Vite + React + Tailwind)",
  "type": "module",
  "author": "open-nova contributors",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:linux": "electron-vite build && electron-builder --linux AppImage flatpak"
  },
  "devDependencies": {
    "@open-nova/core": "*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "dev.opennova.app",
    "productName": "open-nova",
    "electronVersion": "33.4.11",
    "directories": { "output": "release", "buildResources": "build" },
    "files": ["out/**/*", "package.json"],
    "extraResources": [{ "from": "resources", "to": "." }],
    "protocols": [
      { "name": "Nexus Mods Handler", "schemes": ["nxm"], "role": "Viewer" }
    ],
    "linux": {
      "target": ["AppImage", "flatpak"],
      "category": "Game",
      "synopsis": "Mod manager for the FINAL FANTASY XIII trilogy",
      "desktop": { "entry": { "MimeType": "x-scheme-handler/nxm;" } }
    },
    "mac": { "target": "dmg", "category": "public.app-category.utilities" },
    "win": { "target": "nsis" }
  }
}
